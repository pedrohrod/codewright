{
  "name": "codewright",
  "version": "0.3.0",
  "description": "Open-source AI-assisted specification and implementation system",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "bin": {
    "codewright": "dist/cli/main.mjs"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "specification",
    "implementation",
    "cli",
    "codewright"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "glob": "^10.4.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "files": [
    "dist",
    "skills",
    "assets"
  ]
}
